<% layout('layouts/boilerplate') %>
<style>
  /* NEW: Explore page polish styles (clean spacing + active filter) */
  #filters{
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    align-items: center;
    gap: 1rem;
    margin-top: 0.75rem;
  }
  .filter{
    text-align: center;
    margin-right: 1.4rem;
    margin-top: 1.2rem;
    opacity: 0.7;
    transition: all 0.2s ease;
  }
  .filter:hover{
    opacity:1;
    cursor: pointer;
    transform: translateY(-1px);
  }
  .filter{
    font-size: 0.8rem;
  }
  .filter.active-filter{
    opacity: 1;
    color: #fe424d;
    font-weight: 600;
  }
  #tax-info{
    display: none;
  }
  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 2rem;
    display: flex;
    align-items: center;
  }
  /* NEW: Better card spacing and layout consistency */
  .listing-item{
    margin-bottom: 1.2rem;
  }
  .listing-card{
    border-radius: 14px;
    overflow: hidden;
  }
  .listing-price-line{
    line-height: 1.4;
  }
  .wishlist-btn-clean{
    background: none;
    border: none;
    outline: none;
    padding: 0;
  }
  /* NEW: No result message for category filter */
  #noFilterResult{
    display: none;
    text-align: center;
    color: #6c757d;
    font-weight: 500;
    padding: 0.8rem;
  }
</style>
   <div id="filters">
    <!-- data category add kiya help leke -->
      <div class="filter" data-category="all">
       <div><i class="fa-solid fa-border-all"></i></div>
        <p>All</p>
      </div>
      <div class="filter" data-category="trending">
       <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </div>
      <div class="filter" data-category="rooms">
       <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
      </div>
      <div class="filter" data-category="cities">
       <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic Cities</p>
      </div>
      <div class="filter" data-category="mountain">
       <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountain</p>
      </div>
       <div class="filter" data-category="castles">
       <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castles</p>
      </div>
      <div class="filter" data-category="pools">
       <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pool</p>
      </div>
        <div class="filter" data-category="camping">
       <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </div>
       <div class="filter" data-category="farms">
       <div><i class="fa-solid fa-tractor"></i></div>
        <p>Farms</p>
      </div>
      <div class="filter" data-category="arctic">
       <div><i class="fa-solid fa-snowflake"></i></div>
        <p>Arctic</p>
      </div>
           <div class="filter" data-category="domes">
       <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
      </div>
      <div class="filter" data-category="sailboats">
       <div><i class="fa-solid fa-sailboat"></i></div>
        <p>Sailboats</p>
      </div>
      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault"/>
          <label class="form-check-label" for="flexSwitchCheckDefault">Display total after Taxes</label>
        </div>
      </div>
    </div>
    <!-- Yahan tax-toggle wala div khatam ho raha hai -->
   <!-- Professional Price Filter UI -->
<div class="container mb-4 mt-3">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="p-3 shadow-sm border rounded-pill bg-white d-flex align-items-center px-4" style="border-color: #ebebeb !important;">
                
                <form action="/listings/filter" method="GET" class="d-flex align-items-center gap-4 w-100 mb-0">
                    <!-- Price Label aur Slider -->
                    <div class="d-flex align-items-center flex-grow-1">
                        <span class="text-secondary fw-bold me-3" style="white-space: nowrap; font-size: 0.9rem;">
                            Budget: <span class="text-danger" id="priceValueText">₹10,000</span>
                        </span>
                        <!-- Custom Range Slider -->
                        <input type="range" class="form-range" name="price" min="500" max="25000" step="500" id="priceRange" value="10000" 
                               oninput="updatePriceUI(this.value)" style="accent-color: #fe424d; cursor: pointer;">
                    </div>
                    
                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger rounded-pill px-4 btn-sm fw-bold shadow-sm" style="background-color: #fe424d; border: none;">Apply</button>
                        <a href="/listings" class="btn btn-outline-secondary rounded-pill px-3 btn-sm text-decoration-none" style="font-size: 0.8rem;">Reset</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<script>
  function updatePriceUI(val) {
    // Number format (₹10,000) dikhane ke liye logic
    document.getElementById('priceValueText').innerText = "₹" + Number(val).toLocaleString("en-IN");
  }
</script>


    <!-- Ye purani line hai jahan se cards shuru hote hain -->
      <!-- Ye rahi cards -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3" id="listingGrid">
      <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link col listing-item" data-category="<%= listing.category || 'trending' %>">
          <div class="card listing-card">
            <!-- 1. Image -->
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem; object-fit: cover;">
            
            <!-- 2. Card Body (Details + Heart Icon) -->
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mt-2">
                <p class="card-text mb-0">
                  <b><%= listing.title %></b><br />
                  <span class="listing-price-line">₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> /night</span>
                  <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
                </p>

                <!-- Wishlist Heart Icon -->
                <form action="/listings/<%= listing._id %>/wishlist" method="POST">
                  <button type="submit" class="wishlist-btn-clean">
                    <% if (currUser && currUser.wishlist && currUser.wishlist.includes(listing._id)) { %>
  <i class="fa-solid fa-heart" style="color:#fe424d;"></i>
<% } else { %>
  <i class="fa-regular fa-heart"></i>
<% } %>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </a>
      <% } %> <!-- Loop yahan khatam ho raha hai -->
    </div>
    <div id="noFilterResult">No listings found for this filter.</div>



<!-- Tax Toggle Functionality -->
<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("click", ()=>{
    let taxInfo = document.getElementsByClassName("tax-info");
    for (info of taxInfo){
      if(info.style.display != "inline"){
        info.style.display = "inline";
      }else{
        info.style.display = "none";
      }
    }
  });
</script>
<!-- NEW: pass listing titles safely for rotating search placeholder -->
<div id="listingData" data-listings="<%- encodeURIComponent(JSON.stringify(allListings || [])) %>"></div>

<!-- search bar functionality -->
<script>
  let searchInput = document.getElementById("searchInput");
  let listingsDataEl = document.getElementById("listingData");
  let listings = [];
  try {
    listings = JSON.parse(decodeURIComponent(listingsDataEl?.dataset?.listings || "%5B%5D"));
  } catch (e) {
    listings = [];
  }

  let index = 0;

  function changePlaceholder() {
    if (!searchInput || listings.length === 0) return;

    let titles = listings.map(item => item.title);

    searchInput.setAttribute(
      "placeholder",
       titles[index]
    );

    index = (index + 1) % titles.length;
  }

  setInterval(changePlaceholder, 2000);
</script>

<!-- Filter functionality -->
<script>
  let filters = document.querySelectorAll(".filter");
  let items = document.querySelectorAll(".listing-item");
  // NEW: Show a message when selected category has zero items.
  let noFilterResult = document.getElementById("noFilterResult");

  filters.forEach(filter => {
    filter.addEventListener("click", () => {
      let category = filter.getAttribute("data-category");
      let visibleCount = 0;

      // NEW: Active filter state for better UI feedback.
      filters.forEach(f => f.classList.remove("active-filter"));
      filter.classList.add("active-filter");

      items.forEach(item => {
        let itemCategory = (item.getAttribute("data-category") || "").toLowerCase();
        if (category === "all" || itemCategory === category) {
          item.style.display = "block";
          visibleCount++;
        } else {
          item.style.display = "none";
        }
      });

      noFilterResult.style.display = visibleCount === 0 ? "block" : "none";
    });
  });
</script>


 
